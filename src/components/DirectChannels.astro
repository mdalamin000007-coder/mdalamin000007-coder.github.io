---
import { ArrowUpRight, Code2, Globe2, Network, Phone, Send } from "lucide-astro";
import { socialLinks } from "../data/portfolio";

const socialInitials: Record<string, string> = {
  WhatsApp: "WA",
  Facebook: "FB",
  GitHub: "GH",
  LinkedIn: "in"
};
---

<section id="direct-channels" class="section-pad relative overflow-hidden bg-[#050607]" data-section>
  <div class="absolute inset-y-0 left-0 w-px bg-gradient-to-b from-transparent via-[#d9aa59]/40 to-transparent"></div>
  <div class="site-shell grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
    <div>
      <a href="#home" class="magnetic inline-flex items-center gap-3 text-white" aria-label="Mohammad Al Amin home">
        <span class="grid size-12 place-items-center rounded-full bg-white text-sm font-black text-[#02100d]">MA</span>
        <span class="text-2xl font-black">Mohammad Al Amin</span>
      </a>

      <p class="mt-7 max-w-2xl text-pretty text-lg leading-8 text-white/58">
        Premium web developer building Laravel websites, Vue.js and Next.js applications, Flutter mobile apps, and AI automation workflows for modern clients.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        {
          socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noreferrer"
              class="social-pill magnetic grid size-12 place-items-center rounded-[0.8rem] border border-white/12 bg-white/7 text-sm font-black text-white/72 transition hover:border-[#d9aa59]/60 hover:bg-[#d9aa59]/10 hover:text-white"
              aria-label={link.label}
            >
              {socialInitials[link.label] ?? link.label.slice(0, 2)}
            </a>
          ))
        }
      </div>
    </div>

    <div class="lg:pl-8">
      <div class="mb-7 flex items-center gap-3">
        <span class="h-8 w-1 rounded-full bg-[#d9aa59]"></span>
        <h2 class="text-xl font-black uppercase tracking-[0] text-white">Direct Channels</h2>
      </div>

      <div class="space-y-4">
        <a href="https://wa.me/966532313268" target="_blank" rel="noreferrer" class="direct-channel-item magnetic">
          <Phone size={20} strokeWidth={2.2} />
          <span>
            <strong>WhatsApp</strong>
            <small>+966 53 231 3268</small>
          </span>
          <ArrowUpRight size={18} />
        </a>
        <a href="http://facebook.com/md.alamin.0007" target="_blank" rel="noreferrer" class="direct-channel-item magnetic">
          <Globe2 size={20} strokeWidth={2.2} />
          <span>
            <strong>Facebook</strong>
            <small>facebook.com/md.alamin.0007</small>
          </span>
          <ArrowUpRight size={18} />
        </a>
        <a href="https://github.com/mdalamin000007-coder" target="_blank" rel="noreferrer" class="direct-channel-item magnetic">
          <Code2 size={20} strokeWidth={2.2} />
          <span>
            <strong>GitHub</strong>
            <small>mdalamin000007-coder</small>
          </span>
          <ArrowUpRight size={18} />
        </a>
        <a href="https://www.linkedin.com/in/mohammad-alamin-7a2107392/" target="_blank" rel="noreferrer" class="direct-channel-item magnetic">
          <Network size={20} strokeWidth={2.2} />
          <span>
            <strong>LinkedIn</strong>
            <small>mohammad-alamin-7a2107392</small>
          </span>
          <ArrowUpRight size={18} />
        </a>
      </div>

      <a href="#contact" class="premium-button button-primary magnetic mt-8 w-full sm:w-auto">
        Start a Project
        <Send size={18} strokeWidth={2.4} />
      </a>
    </div>
  </div>
</section>
