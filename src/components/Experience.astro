---
import { BriefcaseBusiness, GraduationCap } from "lucide-astro";
import { timeline } from "../data/portfolio";

const icons = [BriefcaseBusiness, GraduationCap];
---

<section id="experience" class="section-pad relative overflow-hidden bg-white/[0.025]" data-section>
  <div class="site-shell grid gap-12 lg:grid-cols-[0.82fr_1.18fr]">
    <div>
      <p class="section-kicker" data-animate>Experience</p>
      <h2 class="mt-6 text-balance text-4xl font-black leading-tight tracking-[0] text-white sm:text-5xl" data-animate>
        A timeline built around learning and shipping.
      </h2>
      <p class="mt-5 text-pretty text-lg leading-8 text-white/62" data-animate>
        Mohammad combines formal computer science study with hands-on company work across websites, applications, mobile products, and AI workflows.
      </p>
    </div>

    <div class="relative">
      <div class="timeline-line absolute bottom-0 left-5 top-0 w-px origin-top bg-gradient-to-b from-[#32f5c8] via-[#59d7ff] to-transparent"></div>
      <div class="space-y-5">
        {
          timeline.map((item, index) => {
            const Icon = icons[index] ?? BriefcaseBusiness;
            return (
              <article class="timeline-item relative pl-16">
                <div class="absolute left-0 top-6 z-10 grid size-10 place-items-center rounded-full border border-[#32f5c8]/40 bg-[#07100f] text-[#32f5c8]">
                  <Icon size={19} strokeWidth={2} />
                </div>
                <div class="timeline-card glass-panel rounded-[1.35rem] p-6">
                  <p class="text-sm font-bold uppercase tracking-[0] text-[#d9aa59]">{item.meta}</p>
                  <h3 class="mt-3 text-2xl font-black text-white">{item.role}</h3>
                  <p class="mt-1 font-bold text-[#32f5c8]">{item.company}</p>
                  <p class="mt-5 text-pretty leading-7 text-white/64">{item.summary}</p>
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </div>
</section>
