---
import { Blocks, Bot, Braces, Code2, Layers3, Smartphone, Workflow } from "lucide-astro";
import { skills } from "../data/portfolio";

const iconMap = [Braces, Layers3, Code2, Smartphone, Workflow, Bot, Blocks];
---

<section id="skills" class="section-pad relative overflow-hidden bg-white/[0.025]" data-section>
  <div class="site-shell">
    <div class="max-w-3xl">
      <p class="section-kicker" data-animate>Skills / Expertise</p>
      <h2 class="mt-6 text-balance text-4xl font-black leading-tight tracking-[0] text-white sm:text-5xl" data-animate>
        Full-stack capability with a modern automation edge.
      </h2>
      <p class="mt-5 max-w-2xl text-pretty text-lg leading-8 text-white/64" data-animate>
        From backend logic to polished product interfaces, Mohammad works across the stack to ship fast, responsive, and useful digital systems.
      </p>
    </div>

    <div class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {
        skills.map((skill, index) => {
          const Icon = iconMap[index] ?? Code2;
          return (
            <article class="skill-card glass-panel group rounded-[1.35rem] p-6">
              <div class="flex items-start justify-between gap-5">
                <div>
                  <p class="text-sm font-bold uppercase tracking-[0] text-[#32f5c8]">{skill.eyebrow}</p>
                  <h3 class="mt-3 text-2xl font-black text-white">{skill.name}</h3>
                </div>
                <div class="grid size-12 shrink-0 place-items-center rounded-2xl border border-white/10 bg-white/8 text-[#d9aa59] transition group-hover:border-[#32f5c8]/50 group-hover:text-[#32f5c8]">
                  <Icon size={24} strokeWidth={1.8} />
                </div>
              </div>
              <p class="mt-6 min-h-21 leading-7 text-white/62">{skill.detail}</p>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
